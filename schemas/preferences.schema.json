{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awf.dev/schemas/preferences.schema.json",
  "title": "AWF v4 User Preferences Schema",
  "description": "User and project preferences for communication, autonomy, quality level, and custom rules.",
  "version": "4.0.0",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "schema_version": { "type": "string", "default": "4.0.0" },
        "awf_version": { "type": "string", "default": "4.0.0" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "communication": {
      "type": "object",
      "properties": {
        "default_language": {
          "type": "string",
          "default": "vi"
        },
        "tone": {
          "type": "string",
          "enum": ["friendly", "professional", "casual", "direct", "custom"],
          "default": "friendly"
        },
        "tone_custom": { "type": "string" },
        "persona": {
          "type": "string",
          "enum": ["assistant", "mentor", "senior_dev", "partner", "coach", "custom"],
          "default": "assistant"
        },
        "persona_custom": { "type": "string" },
        "address_user_as": { "type": "string" },
        "self_reference": { "type": "string" }
      }
    },
    "technical": {
      "type": "object",
      "properties": {
        "detail_level": {
          "type": "string",
          "enum": ["results_only", "simple", "learning", "full_technical"],
          "default": "simple"
        },
        "autonomy": {
          "type": "string",
          "enum": ["ask_often", "balanced", "autonomous"],
          "default": "balanced"
        },
        "quality": {
          "type": "string",
          "enum": ["mvp", "production", "enterprise"],
          "default": "production"
        },
        "technical_level": {
          "type": "string",
          "enum": ["newbie", "basic", "technical"],
          "default": "basic"
        }
      }
    },
    "working_style": {
      "type": "object",
      "properties": {
        "pace": {
          "type": "string",
          "enum": ["careful", "fast"],
          "default": "careful"
        },
        "feedback": {
          "type": "string",
          "enum": ["gentle", "direct", "silent"],
          "default": "direct"
        },
        "confirmation_style": {
          "type": "string",
          "enum": ["milestones", "risky_actions_only", "ask_often"],
          "default": "risky_actions_only"
        }
      }
    },
    "custom_rules": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
